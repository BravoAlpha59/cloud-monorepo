{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyProdSpApiSecretWritesExceptDeploymentRole",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:DeleteSecret",
        "secretsmanager:PutSecretValue",
        "secretsmanager:UpdateSecret"
      ],
      "Resource": "arn:aws:secretsmanager:us-east-2:<PROD-ACCOUNT-ID>:secret:sp-api/*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalArn": "arn:aws:iam::<PROD-ACCOUNT-ID>:role/DeploymentRole"
        }
      }
    }
  ]
}
