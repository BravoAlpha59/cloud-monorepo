{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyProdSpApiSecretWritesExceptDeploymentRole",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:DeleteSecret",
        "secretsmanager:PutSecretValue",
        "secretsmanager:UpdateSecret"
      ],
      "Resource": "arn:aws:secretsmanager:us-east-2:637445353164:secret:sp-api/*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalArn": "arn:aws:iam::637445353164:role/DeploymentRole"
        }
      }
    }
  ]
}
